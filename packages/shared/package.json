{
  "name": "@entelekx/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared contracts and types for EntelekX",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  }
}
